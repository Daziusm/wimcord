# Dependencies & build
node_modules/
dist/
browser/

# Logs & OS
*.log
.DS_Store

# Secrets — never commit
.env
.env.*
!.env.example
**/*.env
!**/*.env.example
# Server deploy (private — not part of the public mod repo)
deploy/

# Local / scratch
.tmp-nightcord/
.agents/
skills-lock.json

# Editor & assistant config (not part of the mod)
.gemini/
.github/*
!.github/workflows/
!.github/workflows/**
.vscode/

# Local settings (user-specific)
settings/*
!settings/.gitkeep

# User plugins may contain private code
src/userplugins/*
!src/userplugins/.gitkeep

# Release artifacts
release/

# Installer upstream cache
.cache/
dist/Installer/.vencord-upstream.exe
